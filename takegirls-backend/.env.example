# ─── Banco de dados (PostgreSQL) ───────────────────────────
# Cole aqui a URL que o Render fornece ao criar o banco
DATABASE_URL=postgresql://usuario:senha@host:5432/takegirls

# ─── JWT (gere uma string aleatória longa e secreta) ───────
JWT_SECRET=coloque_uma_chave_secreta_bem_longa_aqui_1234

# ─── Servidor ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Admin padrão (criado no primeiro setup) ───────────────
ADMIN_EMAIL=admin@takegirls.com
ADMIN_PASSWORD=admin123

# ─── URL do frontend (para o CORS) ─────────────────────────
FRONTEND_URL=https://seu-site.vercel.app
